{
  "version": "urirun.bindings.v8",
  "bindings": {
    "log://pc1/session/command/write": {
      "kind": "service",
      "adapter": "http-service",
      "inputSchema": {
        "type": "object",
        "required": ["event"],
        "properties": {
          "event": { "type": "string" },
          "detail": { "type": "string", "default": "" }
        },
        "additionalProperties": false
      }
    },
    "log://pc1/session/query/recent": {
      "kind": "service",
      "adapter": "http-service",
      "inputSchema": {
        "type": "object",
        "properties": {
          "limit": { "type": "integer", "default": 20 }
        },
        "additionalProperties": false
      }
    },
    "pc://pc1/network/command/ping": {
      "kind": "service",
      "adapter": "http-service",
      "inputSchema": {
        "type": "object",
        "required": ["target"],
        "properties": {
          "target": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "pc://pc2/service/command/start": {
      "kind": "service",
      "adapter": "http-service",
      "inputSchema": {
        "type": "object",
        "required": ["port"],
        "properties": {
          "name": { "type": "string", "default": "demo" },
          "port": { "type": "integer" },
          "message": { "type": "string", "default": "hello from service" }
        },
        "additionalProperties": false
      }
    },
    "pc://pc2/terminal/command/run": {
      "kind": "service",
      "adapter": "http-service",
      "inputSchema": {
        "type": "object",
        "required": ["command"],
        "properties": {
          "command": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "pc://pc3/service/command/start": {
      "kind": "service",
      "adapter": "http-service",
      "inputSchema": {
        "type": "object",
        "required": ["port"],
        "properties": {
          "name": { "type": "string", "default": "demo" },
          "port": { "type": "integer" },
          "message": { "type": "string", "default": "hello from service" }
        },
        "additionalProperties": false
      }
    },
    "pc://pc3/http/command/get": {
      "kind": "service",
      "adapter": "http-service",
      "inputSchema": {
        "type": "object",
        "required": ["url"],
        "properties": {
          "url": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "pc://pc4/http/command/get": {
      "kind": "service",
      "adapter": "http-service",
      "inputSchema": {
        "type": "object",
        "required": ["url"],
        "properties": {
          "url": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "app://pc1/notes/command/add": {
      "kind": "service",
      "adapter": "http-service",
      "inputSchema": {
        "type": "object",
        "required": ["text"],
        "properties": {
          "text": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "app://pc1/notes/query/list": {
      "kind": "service",
      "adapter": "http-service",
      "inputSchema": {
        "type": "object",
        "properties": {
          "limit": { "type": "integer", "default": 20 }
        },
        "additionalProperties": false
      }
    },
    "app://pc2/orders/command/create": {
      "kind": "service",
      "adapter": "http-service",
      "inputSchema": {
        "type": "object",
        "required": ["item"],
        "properties": {
          "item": { "type": "string" },
          "quantity": { "type": "integer", "default": 1 }
        },
        "additionalProperties": false
      }
    },
    "app://pc2/orders/query/list": {
      "kind": "service",
      "adapter": "http-service",
      "inputSchema": {
        "type": "object",
        "properties": {
          "limit": { "type": "integer", "default": 20 }
        },
        "additionalProperties": false
      }
    },
    "app://pc3/reports/command/render": {
      "kind": "service",
      "adapter": "http-service",
      "inputSchema": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "title": { "type": "string" },
          "source": { "type": "string", "default": "orders" }
        },
        "additionalProperties": false
      }
    },
    "app://pc3/reports/query/latest": {
      "kind": "service",
      "adapter": "http-service",
      "inputSchema": {
        "type": "object",
        "properties": {
          "limit": { "type": "integer", "default": 1 }
        },
        "additionalProperties": false
      }
    },
    "app://pc4/monitor/command/check": {
      "kind": "service",
      "adapter": "http-service",
      "inputSchema": {
        "type": "object",
        "required": ["target"],
        "properties": {
          "target": { "type": "string" },
          "level": { "type": "string", "default": "normal" }
        },
        "additionalProperties": false
      }
    },
    "app://pc4/monitor/query/status": {
      "kind": "service",
      "adapter": "http-service",
      "inputSchema": {
        "type": "object",
        "properties": {
          "limit": { "type": "integer", "default": 5 }
        },
        "additionalProperties": false
      }
    }
  }
}
