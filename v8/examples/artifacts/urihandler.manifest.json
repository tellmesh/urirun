{
  "version": "urirun.bindings.v8",
  "bindings": {
    "tool://local/report/render": {
      "kind": "command",
      "adapter": "argv-template",
      "inputSchema": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" }
        },
        "additionalProperties": false
      },
      "argv": ["python3", "-c", "import sys; print('report for ' + sys.argv[1])", "{name}"]
    }
  }
}
