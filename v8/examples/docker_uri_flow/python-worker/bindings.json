{
  "version": "urirun.bindings.v8",
  "bindings": {
    "python://python-worker/text/normalize": {
      "kind": "command",
      "adapter": "local-service",
      "inputSchema": {
        "type": "object",
        "required": ["text"],
        "properties": {
          "text": { "type": "string" }
        },
        "additionalProperties": false
      },
      "meta": { "label": "Normalize text", "language": "python" }
    },
    "python://python-worker/report/summary": {
      "kind": "query",
      "adapter": "local-service",
      "inputSchema": {
        "type": "object",
        "required": ["path"],
        "properties": {
          "path": { "type": "string" }
        },
        "additionalProperties": false
      },
      "meta": { "label": "Summarize report", "language": "python" }
    }
  }
}
