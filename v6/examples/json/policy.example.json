{
  "version": "urihandler.policy.v6",
  "defaultMode": "dry-run",
  "execute": {
    "allow": [
      "cli://local/npm/*",
      "cli://local/make/*"
    ],
    "deny": [
      "cli://local/script/*"
    ]
  },
  "allowShellTemplates": false,
  "allowShell": false,
  "maxArgs": 16,
  "timeout": 30
}
