{
  "version": "urirun.bindings.v2",
  "bindings": {
    "fs://laptop/file/command/write-b64": {
      "uri": "fs://laptop/file/command/write-b64",
      "kind": "local-function",
      "adapter": "local-function-subprocess",
      "python": {
        "type": "python",
        "module": "fs_transfer",
        "export": "write_b64"
      },
      "policy": {
        "allowExecute": true
      },
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string",
            "default": ""
          },
          "bytes_b64": {
            "type": "string",
            "default": ""
          },
          "overwrite": {
            "type": "boolean",
            "default": false
          },
          "make_dirs": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "meta": {
        "connector": "fs-transfer",
        "label": "Write one base64 file to the node"
      }
    },
    "fs://laptop/file/query/read-b64": {
      "uri": "fs://laptop/file/query/read-b64",
      "kind": "local-function",
      "adapter": "local-function-subprocess",
      "python": {
        "type": "python",
        "module": "fs_transfer",
        "export": "read_b64"
      },
      "policy": {
        "allowExecute": true
      },
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string",
            "default": ""
          },
          "max_bytes": {
            "type": "integer",
            "default": 3000000
          }
        }
      },
      "meta": {
        "connector": "fs-transfer",
        "label": "Read one node file as base64"
      }
    }
  }
}
