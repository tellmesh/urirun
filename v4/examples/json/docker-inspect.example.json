[
  {
    "Id": "container-user-service",
    "Name": "user-service",
    "Config": {
      "Labels": {
        "urihandler.enabled": "true",
        "urihandler.uri": "service://api/user/create/basic",
        "urihandler.kind": "http",
        "urihandler.adapter": "fetch",
        "urihandler.method": "POST",
        "urihandler.url": "http://user-service:8080/api/users"
      }
    }
  },
  {
    "Id": "container-mqtt-bridge",
    "Name": "mqtt-bridge",
    "Config": {
      "Labels": {
        "urihandler.enabled": "true",
        "urihandler.package": "mqtt",
        "urihandler.target": "broker",
        "urihandler.resource": "publish",
        "urihandler.operation": "home",
        "urihandler.kind": "mqtt",
        "urihandler.adapter": "mqtt-publish",
        "urihandler.topicPrefix": "home"
      }
    }
  }
]
