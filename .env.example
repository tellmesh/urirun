# urirun LLM Configuration
# Choose ONE active API provider by uncommenting the matching block.

# =============================================================================
# Option 1: Anthropic direct — Claude Sonnet 4.6 (recommended for GUI tasks)
# =============================================================================
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
# Model — DeepSeek V4 Pro: minimum baseline (2026-05-10).
# Empiryczny test (docs/SESSION-2026-05-09-summary.md sekcja 5b):
# V4 Pro daje idiomatyczny refactor (Counter), V4 Flash halucynuje semantykę.
# Cena: input $0.435/M, output $0.870/M, context 1M tokens.
#LLM_MODEL=openrouter/deepseek/deepseek-v4-pro
#LLM_MODEL=openrouter/qwen/qwen3.7-plus
LLM_MODEL=openrouter/minimax/minimax-m3
#LLM_MODEL=openrouter/google/gemini-3.1-flash-image-preview
#LLM_MODEL=openrouter/google/gemini-3.5-flash
#URIRUN_LLM_MODEL=openrouter/google/gemini-3.1-flash-image-preview

# =============================================================================
# Option 2: OpenRouter (comment out Option 1 above, uncomment this block)
# =============================================================================
# OPENROUTER_API_KEY=
# LLM_MODEL=openrouter/qwen/qwen3-coder-next

# Other OpenRouter models:
# LLM_MODEL=openrouter/anthropic/claude-sonnet-4-6
# LLM_MODEL=openrouter/openai/gpt-4o

# =============================================================================
# pfix — Self-healing Python (auto-fixes runtime errors via LLM)
# =============================================================================
PFIX_AUTO_APPLY=true         # true = apply fixes without asking
PFIX_AUTO_INSTALL_DEPS=true  # true = auto pip/uv install
PFIX_AUTO_RESTART=false      # true = os.execv restart after fix
PFIX_MAX_RETRIES=3
PFIX_DRY_RUN=false
PFIX_ENABLED=true

# Git integration
PFIX_GIT_COMMIT=false        # true = auto-commit fixes
PFIX_GIT_PREFIX=pfix:        # commit message prefix

# Backup
PFIX_CREATE_BACKUPS=false    # false = disable .pfix_backups/ directory
